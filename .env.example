# Which provider sends the contact emails: "resend" (default) or "smtp"
EMAIL_PROVIDER=resend

# Verified sender address used as the "from" for both emails
EMAIL_FROM="Lunar Studio <hello@yourdomain.com>"

# Where lead notifications are delivered (our inbox)
LEADS_INBOX=team@yourdomain.com

# --- Resend (used when EMAIL_PROVIDER=resend) ---
RESEND_API_KEY=

# --- SMTP (used when EMAIL_PROVIDER=smtp) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
